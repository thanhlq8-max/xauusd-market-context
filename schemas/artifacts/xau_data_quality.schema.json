{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "xau_data_quality",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "ts_utc",
    "symbol",
    "monitor_only",
    "freshness_score",
    "coverage_score",
    "schema_score",
    "source_count",
    "confidence_cap",
    "present_timeframes",
    "errors",
    "quality_flags"
  ],
  "properties": {
    "ts_utc": {
      "type": "string"
    },
    "symbol": {
      "type": "string"
    },
    "monitor_only": {
      "type": "boolean",
      "const": true
    },
    "freshness_score": {
      "type": "number"
    },
    "coverage_score": {
      "type": "number"
    },
    "schema_score": {
      "type": "number"
    },
    "source_count": {
      "type": "integer"
    },
    "confidence_cap": {
      "type": "number"
    },
    "present_timeframes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array"
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dispersion_score": {
      "type": "number"
    },
    "event_count": {
      "type": "integer"
    },
    "missing_field_count": {
      "type": "integer"
    },
    "news_risk_flag": {
      "type": "boolean"
    },
    "session_completeness": {
      "type": "number"
    },
    "spread_stability": {
      "type": "number"
    }
  }
}
